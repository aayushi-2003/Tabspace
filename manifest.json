{
  "manifest_version": 3,
  "name": "Tabspace",
  "version": "1.0",
  "permissions": [
    "storage",
    "tabs",
    "sidePanel"
  ],
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "side_panel": {
  "default_path": "sidepanel/dist/index.html"
  },
  "action": {
    "default_popup": "sidepanel/dist/popup.html"
  }
}
